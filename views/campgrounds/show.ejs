<% layout('layouts/boilerplate') %>

<div class="row">
    <div class="col-12 col-md-8 offset-md-2">
        <div class="card mb-4 shadow-sm">
            <img src="<%= campground.image %>" class="card-img-top" alt="Campground Image">
            <div class="card-body">
                <h3 class="card-title"><%= campground.title %></h3>
                <p class="card-text"><%= campground.description %></p>
            </div>
            <ul class="list-group list-group-flush">
                <li class="list-group-item text-muted">📍 <%= campground.location %></li>
                <li class="list-group-item fw-bold">💲<%= campground.price %> / night</li>
            </ul>
            <div class="card-body d-flex justify-content-between">
                <a class="btn btn-outline-info" href="/campgrounds/<%= campground._id %>/edit">✏️ Edit</a>
                <form class="d-inline" action="/campgrounds/<%= campground._id %>?_method=DELETE" method="POST">
                    <button class="btn btn-outline-danger" onclick="return confirm('Are you sure you want to delete this campground?')">🗑️ Delete</button>
                </form>
            </div>
            <div class="card-footer text-muted text-end">
                Posted 2 days ago
            </div>
        </div>
        <div class="text-center">
            <a href="/campgrounds" class="btn btn-secondary">← Back to All Campgrounds</a>
        </div>
    </div>
</div>
